{
  "name": "@ethereal/genui-react",
  "version": "0.1.0",
  "description": "Ethereal GenUI React renderer — renders AI-emitted JSON specs as real React components",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": ["dist", "src/theme.css"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@ethereal/genui-core": "^0.1.0",
    "@ag-ui/core": "^0.0.57"
  },
  "devDependencies": {
    "@ethereal/genui-core": "file:../ethereal-genui-core",
    "@ag-ui/core": "^0.0.57",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
